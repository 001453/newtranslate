# Privacy & QVAC Local AI — https://qvac.tether.io/
LOCAL_PROCESSING_ONLY=true
TRANSLATION_PROVIDER=qvac
QVAC_BRIDGE_URL=http://127.0.0.1:8765
QVAC_BRIDGE_PORT=8765
QVAC_LLM_MODEL=QWEN3_600M_INST_Q4
ALLOW_CLOUD_FALLBACK=false

# Together AI (cloud mode only — data leaves device)
TOGETHER_API_KEY=

# Models (Together AI — optional fallback)
TRANSLATION_MODEL=Qwen/Qwen2.5-72B-Instruct-Turbo
TRANSLATION_FALLBACK_MODEL=meta-llama/Meta-Llama-3.1-70B-Instruct-Turbo
SUMMARY_MODEL=meta-llama/Meta-Llama-3.1-70B-Instruct-Turbo

# Whisper STT (always local — faster-whisper in Python backend)
WHISPER_MODEL=large-v3
WHISPER_DEVICE=auto
WHISPER_COMPUTE_TYPE=float16
# STT routing: whisper (default) | qvac (whisper.cpp via bridge) | auto
STT_PROVIDER=whisper
QVAC_WHISPER_MODEL=WHISPER_BASE_Q8_0

# Optional third-party (not used in Sovereign Mode)
DEEPL_API_KEY=
ELEVENLABS_API_KEY=
TTS_ENABLED=false

# Privacy
OFFLINE_MODE=false
AUTO_DELETE_SESSIONS_HOURS=24

# Security (sovereign local defaults)
# API binds to 127.0.0.1 only — not reachable from LAN/internet
API_BIND_HOST=127.0.0.1
# Optional: set a secret when exposing API on LAN (requires X-API-Key header)
API_KEY=
MAX_UPLOAD_BYTES=52428800
MAX_BATCH_UPLOADS=10

# Database
DATABASE_URL=sqlite+aiosqlite:///./data/globalbridge.db

# CORS
CORS_ORIGINS=http://localhost:3000,http://localhost:3001,http://localhost:3002,http://localhost:3003,http://127.0.0.1:3000,http://127.0.0.1:3001,http://127.0.0.1:3002

# Frontend
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_WS_URL=ws://localhost:8000/api/v1/ws/live

# Electron overlay (optional)
GB_WS_URL=ws://localhost:8000/api/v1/ws/live

# Services (all required for full stack):
# npm run setup && npm run dev
# QVAC 8765 | Backend 8000 | Frontend 3000
